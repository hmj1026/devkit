{
    "name": "hmj1026/devkit",
    "description": "Generic PHP/Laravel dev kit — unified entity audit logging, Http gateway, Elasticsearch toolkit, SMS dispatch, file uploader, Google Chat logger, and Laravel helpers. Targets PHP 7.3 → 8.x and Laravel 6 → 11.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "laravel",
        "audit-log",
        "elasticsearch",
        "http-gateway",
        "sms",
        "monolog",
        "google-chat",
        "flysystem"
    ],
    "authors": [
        {
            "name": "hmj1026",
            "homepage": "https://github.com/hmj1026"
        }
    ],
    "require": {
        "php": "^7.3 || ^8.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "psr/simple-cache": "^1.0 || ^2.0 || ^3.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "monolog/monolog": "^2.9 || ^3.0",
        "symfony/http-kernel": "^4.4 || ^5.0 || ^6.0 || ^7.0",
        "guzzlehttp/guzzle": "^7.0",
        "league/flysystem": "^1.1 || ^2.0 || ^3.0",
        "elasticsearch/elasticsearch": "^7.17",
        "butschster/meta-tags": "^2.1 || ^3.0",
        "jenssegers/agent": "^2.0",
        "aws/aws-sdk-php": "^3.0",
        "illuminate/support": "^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "laravel/framework": "^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0",
        "league/flysystem-memory": "^1.0 || ^2.0 || ^3.0",
        "mockery/mockery": "^1.3 || ^1.5",
        "orchestra/testbench": "^4.0 || ^5.0 || ^6.0 || ^7.0 || ^8.0 || ^9.0",
        "phpunit/phpunit": "^8.5 || ^9.6"
    },
    "suggest": {
        "aws/aws-sdk-php": "Required only when signing Elasticsearch requests for AWS-managed domains via Devkit\\Search\\Foundation\\AwsSignedHandler (^3.0)."
    },
    "autoload": {
        "psr-4": {
            "Devkit\\": "src/"
        },
        "files": [
            "src/Laravel/Database/Cast/polyfills.php",
            "src/Core/Support/helpers.php",
            "src/Core/Validation/functions.php",
            "src/Laravel/Http/Support/helpers.php",
            "src/Laravel/Ui/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Devkit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devkit\\Laravel\\DevkitServiceProvider"
            ],
            "aliases": {
                "Trail": "Devkit\\Laravel\\Ui\\Facades\\Trail",
                "MetaTags": "Devkit\\Laravel\\Ui\\Facades\\MetaTags",
                "HttpUri": "Devkit\\Laravel\\Http\\Facades\\HttpUri",
                "Sms": "Devkit\\Laravel\\Messaging\\Facades\\Sms",
                "FileUploader": "Devkit\\Laravel\\Storage\\Facades\\FileUploader",
                "Elasticsearch": "Devkit\\Laravel\\Search\\Facades\\Elasticsearch"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "scripts": {
        "test:core": "phpunit --testsuite=core",
        "test:laravel": "phpunit --testsuite=laravel",
        "test:unit": [
            "@test:core",
            "@test:laravel"
        ],
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "matrix:install": "@php scripts/matrix-install.php",
        "matrix:list": "@php scripts/matrix-install.php --list",
        "matrix:test": [
            "@matrix:install",
            "@test:unit"
        ]
    },
    "scripts-descriptions": {
        "matrix:install": "Install deps for a CI matrix cell. Usage: composer matrix:install -- <php> <laravel> [--lowest|--dry-run]. Cleanup afterwards: git checkout -- composer.json composer.lock && composer install",
        "matrix:list": "List every (php, laravel) cell declared in .github/workflows/tests.yml",
        "matrix:test": "Install matrix cell then run both core+laravel testsuites. Usage: composer matrix:test -- <php> <laravel>"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
